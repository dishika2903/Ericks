      "post": {
        "summary": "Request Package Delivery",
        "description": "Creates delivery booking detailing fragile constraints, package parameters, and dropoff coordinates.",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
